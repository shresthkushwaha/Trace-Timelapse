{
    "name": "trace-timelapse",
    "version": "1.2.0",
    "description": "Desktop timelapse utility for automatic screen capture",
    "main": "src/main/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "electron": "electron .",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "dist": "npm run build && electron-builder"
    },
    "keywords": [
        "electron",
        "timelapse",
        "screen-capture"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "electron-squirrel-startup": "^1.0.1",
        "ffmpeg-static": "^5.2.0",
        "fluent-ffmpeg": "^2.1.3",
        "framer-motion": "^12.34.0",
        "fs-extra": "^11.2.0",
        "screenshot-desktop": "^1.15.0"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "concurrently": "^8.2.2",
        "electron": "^28.2.0",
        "electron-builder": "^24.9.1",
        "postcss": "^8.4.35",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.4.1",
        "vite": "^5.0.12",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.trace.timelapse",
        "productName": "Trace",
        "icon": "build/icon-256.png",
        "asar": true,
        "asarUnpack": [
            "node_modules/screenshot-desktop/**/*"
        ],
        "files": [
            "dist/**/*",
            "src/main/**/*",
            "package.json"
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        },
        "extraResources": [
            {
                "from": "node_modules/ffmpeg-static",
                "to": "ffmpeg-static",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}